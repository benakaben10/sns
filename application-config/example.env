# ── HTTP ──────────────────────────────────────────────────────────────────────
HTTP_PORT=8080

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgres://notifsvc:notifpass@localhost:5432/notifdb?sslmode=disable

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_EMAIL_SEND_TOPIC=email.send
KAFKA_EMAIL_RESULT_TOPIC=email.result
KAFKA_CONSUMER_GROUP=notification-service

# ── Channel ────────────────────────────────────────────────────────────────────
CHANNEL_BUFFER_SIZE=1000

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Mode: symmetric | jwks
JWT_AUTH_MODE=symmetric
JWT_HMAC_SECRET=change-me-in-production
JWT_ISSUER=notification-service-local
JWT_AUDIENCE=notification-service

# Only used when JWT_AUTH_MODE=jwks (Keycloak / Auth0 / OIDC)
# JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# JWT_ISSUER=https://auth.example.com/realms/myrealm
# JWT_AUDIENCE=notification-service
